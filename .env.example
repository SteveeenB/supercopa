# =============================================================================
# Plantilla de variables de entorno para supercopa (MS2 + MS3).
# Copia este archivo a `.env` (ignorado por git) y rellena con tus valores
# reales. NUNCA commitees `.env`.
#
# Para producción (DigitalOcean App Platform), pega estos mismos valores en:
#   App → componente supercopa → Settings → App-Level Environment Variables.
#   Marca DB_PASSWORD como "Encrypted".
# =============================================================================

# ---- Puerto del servidor (default 8082) ----
SERVER_PORT=8082

# ---- Base de datos PostgreSQL (Supabase) ----
# Pega aquí la URL que aparece en Supabase → Project Settings → Database → Connection string (JDBC).
# Para el pooler (recomendado en App Platform), usa el host con :6543.
DB_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.zfjnyewmrlhtviwnxqew
DB_PASSWORD_MS2=__SET_ME__

# ---- JWT (MS1 emite los tokens; MS2 los valida con la JWK pública de MS1) ----
# Local: http://localhost:8081
# Producción: https://authcodecup-cykcc.ondigitalocean.app
CODECUP_JWT_ISSUER=http://localhost:8081

# ---- URL base de MS1 para llamadas inter-MS (Ms1JugadoresClient) ----
# Mismo valor que CODECUP_JWT_ISSUER en este proyecto.
MS1_BASE_URL=http://localhost:8081

# ---- Frontend (usado por CORS en SecurityConfig) ----
# Local: http://localhost:5173
# Producción: https://codecup.games
FRONTEND_URL=http://localhost:5173

# ---- JVM opts (solo necesario en producción) ----
# Para DO Basic XS (512 MB):  -Xmx400m -XX:+UseSerialGC -XX:MaxMetaspaceSize=128m
# Para DO Basic S  (1 GB):    -Xmx768m -XX:+UseG1GC
JAVA_OPTS=
